---
/**
 * SynthMark — V5 Synthetic Print animated logo for the website.
 * Vanilla JS port of packages/ui/src/components/SynthMark.tsx.
 * Renders the tapered fingerprint mark with breathing animation.
 */
interface Props {
  size?: number;
}

const { size = 20 } = Astro.props;
const canvasId = `synth-mark-${Math.random().toString(36).slice(2, 8)}`;
---

<canvas
  id={canvasId}
  style={`width:${size}px;height:${size}px`}
  aria-label="Synth logo"
  role="img"
></canvas>

<script define:vars={{ canvasId, size }}>
  (function () {
    const c = document.getElementById(canvasId);
    if (!c) return;
    const ctx = c.getContext("2d");
    if (!ctx) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 3);
    c.width = size * dpr;
    c.height = size * dpr;
    ctx.scale(dpr, dpr);

    const rgb = "107,138,255";
    let frame = 0;

    function draw() {
      frame++;
      const f = frame * 3;
      ctx.clearRect(0, 0, size, size);

      const cx = size / 2;
      const cy = size / 2;
      const sc = size / 78;
      const lines = 7;
      const spacing = 5.5;
      const sX = -36;
      const eX = 36;
      const segs = 36;

      for (let i = 0; i < lines; i++) {
        const y = (i - (lines - 1) / 2) * spacing;
        const center = Math.abs(i - (lines - 1) / 2) / ((lines - 1) / 2);
        const baseA = 0.35 + (1 - center) * 0.65;

        for (let s = 0; s < segs; s++) {
          const t1 = s / segs;
          const t2 = (s + 1) / segs;
          const x1 = sX + t1 * (eX - sX);
          const x2 = sX + t2 * (eX - sX);

          const w1 = (1.2 + t1 * 3) * (1 - center * 0.5);

          const breathe = 1 + Math.sin(f * 0.012 + i * 0.6) * 0.15 * (1 - t1);

          const wave1 = (1 - t1) * (1 - t1) * breathe;
          const wave2 = (1 - t2) * (1 - t2) * breathe;
          const amp1 = (5 + Math.sin(i * 1.3) * 2.5) * wave1;
          const amp2 = (5 + Math.sin(i * 1.3) * 2.5) * wave2;
          const freq = 2.8 + i * 0.5;
          const wy1 = Math.sin(t1 * freq * Math.PI + i * 0.8) * amp1;
          const wy2 = Math.sin(t2 * freq * Math.PI + i * 0.8) * amp2;

          const shimmer = 0.85 + Math.sin(f * 0.02 + i * 0.6) * 0.15;
          const alpha = baseA * (0.45 + t1 * 0.55) * shimmer;
          ctx.strokeStyle = `rgba(${rgb},${alpha})`;
          ctx.lineWidth = Math.max(0.8, w1 * sc);
          ctx.lineCap = "round";
          ctx.beginPath();
          ctx.moveTo(cx + x1 * sc, cy + (y + wy1) * sc);
          ctx.lineTo(cx + x2 * sc, cy + (y + wy2) * sc);
          ctx.stroke();
        }
      }

      // Endpoint dot
      const dotAlpha = 0.6 + Math.sin(f * 0.025) * 0.2;
      const dotSize = 3 + Math.sin(f * 0.02) * 0.3;
      ctx.fillStyle = `rgba(${rgb},${dotAlpha})`;
      ctx.beginPath();
      ctx.arc(cx + 38 * sc, cy, Math.max(1.5, dotSize * sc), 0, Math.PI * 2);
      ctx.fill();

      requestAnimationFrame(draw);
    }

    draw();
  })();
</script>
