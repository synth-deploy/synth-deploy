---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  tags: string[];
  slug: string;
}

const { title, description, pubDate, author, tags, slug } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<a href={`/blog/${slug}`} class="block glass-card p-6 hover:border-ds-accent-border transition-colors group">
  <div class="flex items-center gap-2 text-xs text-ds-text-muted mb-3">
    <span>{author}</span>
    <span>&middot;</span>
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
  </div>
  <h2 class="text-lg font-semibold text-ds-text group-hover:text-ds-accent transition-colors mb-2">
    {title}
  </h2>
  <p class="text-sm text-ds-text-secondary line-clamp-2 mb-4">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="inline-block rounded border border-ds-border px-2 py-0.5 text-[11px] text-ds-text-muted">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
