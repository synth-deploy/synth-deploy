          class="rounded-md border border-ds-border px-6 py-3 text-ds-text hover:border-ds-accent-border hover:bg-ds-surface transition-colors"
        >
          Read the Docs
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .guide-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateX(-8px);
  }
  .guide-nav-link.visible {
    opacity: 1;
    transform: translateX(0);
  }
  .guide-nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: all 0.3s ease;
    opacity: 0.25;
  }
  .guide-nav-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    color: rgba(154, 151, 144, 0.4);
    transition: all 0.3s ease;
    white-space: nowrap;
  }
  .guide-nav-link:hover .guide-nav-label {
    color: rgba(154, 151, 144, 0.8);
  }
  .guide-nav-link:hover .guide-nav-dot {
    opacity: 0.6;
  }

  /* Visited = section has been scrolled past or is current */
  .guide-nav-link.visited .guide-nav-dot {
    opacity: 0.6;
  }
  .guide-nav-link.visited .guide-nav-label {
    color: rgba(228, 226, 222, 0.5);
  }

  /* Active = currently in viewport */
  .guide-nav-link.active .guide-nav-dot {
    opacity: 1;
    width: 8px;
    height: 8px;
    box-shadow: 0 0 8px currentColor;
  }
  .guide-nav-link.active .guide-nav-label {
    color: #e4e2de;
    font-weight: 600;
  }
</style>

<script>
  // Scroll-reveal observer
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
  );
  document.querySelectorAll(".scroll-reveal").forEach((el) => revealObserver.observe(el));

  // Guide sidebar scroll-spy
  const nav = document.getElementById("guide-nav");
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>(".guide-nav-link");
    const sectionIds = Array.from(links).map((l) => l.dataset.spy!);
    const sections = sectionIds.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    const visited = new Set<string>();

    let navShown = false;
    let firstReveal = true;

    function showNav() {
      if (navShown) return;
      navShown = true;
      nav.style.pointerEvents = "auto";
      if (firstReveal) {
        firstReveal = false;
        links.forEach((link, i) => {
          setTimeout(() => link.classList.add("visible"), i * 60);
        });
      } else {
        links.forEach((link) => link.classList.add("visible"));
      }
    }

    function hideNav() {
      if (!navShown) return;
      navShown = false;
      nav.style.pointerEvents = "none";
      links.forEach((link) => link.classList.remove("visible"));
    }

    // Watch the hero — hide nav when hero is visible, show when it's not
    const hero = document.querySelector("section:first-of-type");
    if (hero) {
      const heroObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              hideNav();
            } else {
              showNav();
            }
          });
        },
        { threshold: 0.15 },
      );
      heroObserver.observe(hero);
    }

    // Smooth scroll on click
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const id = link.dataset.spy!;
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", `#${id}`);
        }
      });
    });

    // Track which section is in view
    const spyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          if (entry.isIntersecting) {
            visited.add(id);
            links.forEach((link) => {
              const spy = link.dataset.spy!;
              link.classList.toggle("active", spy === id);
              link.classList.toggle("visited", visited.has(spy) && spy !== id);
            });
          }
        });
      },
      { threshold: 0, rootMargin: "-30% 0px -50% 0px" },
    );

    sections.forEach((section) => spyObserver.observe(section));
  }
</script>
