---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";

const communityFeatures = [
  "Intelligent deployment planning",
  "Artifact analysis with LLM reasoning",
  "6 execution handlers (file, process, config, container, service, verify)",
  "Full Debrief decision log",
  "Variable resolution with conflict detection",
  "Dry-run observations before execution",
  "REST API and MCP server",
  "Any LLM provider (Claude, GPT, Gemini, Ollama, etc.)",
  "Artifact annotations — operator corrections that improve future analysis",
  "Up to 10 registered Envoys",
];

const enterpriseFeatures = [
  { name: "Unlimited Envoys", desc: "Scale beyond 10 registered agents" },
  { name: "Fleet Deployments", desc: "Batched rollouts and canary strategies across envoy groups" },
  { name: "Deployment Graphs", desc: "Multi-artifact dependency graphs with intelligent ordering" },
  { name: "SSO", desc: "OIDC, SAML, and LDAP authentication" },
  { name: "Custom Roles", desc: "Granular permissions beyond the built-in roles" },
  { name: "Multi-Provider LLM", desc: "Fallback chains across multiple LLM providers" },
  { name: "Task Model Routing", desc: "Route different tasks to different models" },
  { name: "LLM Postmortems", desc: "Auto-generated postmortem analysis for failed deployments" },
  { name: "MCP Servers", desc: "Register external MCP servers for tool integration" },
  { name: "Co-Branding", desc: "Custom operator name, logo, and accent color" },
  { name: "Telemetry Export", desc: "Export deployment telemetry to external systems" },
  { name: "Configurable Retention", desc: "Custom debrief and history retention policies" },
];
---

<Layout title="Synth — Pricing" description="Community and Enterprise editions. Free for teams up to 10 Envoys. Pioneer Program for early partners.">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-ds-accent/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-1/3 right-1/3 w-80 h-80 bg-ds-succeeded/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 pt-24 pb-16 text-center">
      <div class="animate-fade-in-up">
        <h1 class="text-5xl md:text-6xl font-display font-bold leading-tight mb-6">
          One product.<br />
          <span class="text-ds-accent">Two ways to run it.</span>
        </h1>
        <p class="text-xl text-ds-text-secondary max-w-2xl mx-auto leading-relaxed">
          Synth is source-available under the Business Source License.
          Community is free forever. Enterprise unlocks scale and operational features.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pb-28">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Community -->
        <div class="glass-card p-8 flex flex-col scroll-reveal">
          <div class="flex items-center gap-2 mb-2">
            <div class="entity-badge border-ds-accent-border bg-ds-accent-dim text-ds-accent text-[10px] py-0.5">
              Community
            </div>
          </div>
          <div class="mb-6">
            <p class="text-4xl font-display font-bold text-ds-text">Free</p>
            <p class="text-sm text-ds-text-muted mt-1">Source-available. Self-hosted. No strings.</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            {communityFeatures.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-ds-text-secondary">
                <span class="text-ds-succeeded mt-0.5 shrink-0">&#10003;</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a
            href="https://github.com/synth-deploy/synth-deploy"
            target="_blank"
            rel="noopener"
            class="block text-center rounded-md border border-ds-accent-border bg-ds-accent-dim px-6 py-3 text-ds-accent font-semibold hover:bg-ds-accent-hover transition-colors"
          >
            Get Started
          </a>
        </div>

        <!-- Enterprise -->
        <div class="glass-card p-8 flex flex-col border-ds-accent/30 scroll-reveal scroll-reveal-delay-1">
          <div class="flex items-center gap-2 mb-2">
            <div class="entity-badge border-ds-accent/40 bg-ds-accent/10 text-ds-accent text-[10px] py-0.5">
              Enterprise
            </div>
          </div>
          <div class="mb-6">
            <p class="text-4xl font-display font-bold text-ds-text">Licensed</p>
            <p class="text-sm text-ds-text-muted mt-1">Everything in Community, plus:</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            {enterpriseFeatures.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-ds-text-secondary">
                <span class="text-ds-accent mt-0.5 shrink-0">&#10003;</span>
                <span><strong class="text-ds-text">{f.name}</strong> — {f.desc}</span>
              </li>
            ))}
          </ul>
          <ContactForm
            formType="enterprise"
            buttonText="Contact for Licensing"
            id="enterprise-form"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Pioneer Program -->
  <section class="py-28 border-t border-ds-border relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-ds-partition/5 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-5xl px-6">
      <div class="text-center mb-16 scroll-reveal">
        <p class="section-heading">Pioneer Program</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
          Get Enterprise for free. Help shape the product.
        </h2>
        <p class="text-ds-text-secondary text-lg max-w-2xl mx-auto">
          We're looking for engineering teams willing to run Synth in real environments,
          surface rough edges, and tell us what's missing. In exchange, you get full
          Enterprise access at no cost.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="glass-card p-6 scroll-reveal scroll-reveal-delay-1">
          <h3 class="text-base font-semibold mb-2 text-ds-text">What you get</h3>
          <ul class="space-y-2 text-sm text-ds-text-secondary">
            <li class="flex items-start gap-2">
              <span class="text-ds-succeeded mt-0.5 shrink-0">&#10003;</span>
              <span>Full Enterprise license — all 13 features, unlimited Envoys</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-ds-succeeded mt-0.5 shrink-0">&#10003;</span>
              <span>Direct access to the maintainer for support and feedback</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-ds-succeeded mt-0.5 shrink-0">&#10003;</span>
              <span>Influence on roadmap priorities based on your use cases</span>
            </li>
          </ul>
        </div>

        <div class="glass-card p-6 scroll-reveal scroll-reveal-delay-2">
          <h3 class="text-base font-semibold mb-2 text-ds-text">What we ask</h3>
          <ul class="space-y-2 text-sm text-ds-text-secondary">
            <li class="flex items-start gap-2">
              <span class="text-ds-accent mt-0.5 shrink-0">&rarr;</span>
              <span>Run Synth against real deployment workflows</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-ds-accent mt-0.5 shrink-0">&rarr;</span>
              <span>Report bugs, friction, and feature gaps honestly</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-ds-accent mt-0.5 shrink-0">&rarr;</span>
              <span>Allow us to list your company logo on this site</span>
            </li>
          </ul>
        </div>

        <div class="glass-card p-6 scroll-reveal scroll-reveal-delay-3">
          <h3 class="text-base font-semibold mb-2 text-ds-text">Good fit if you</h3>
          <ul class="space-y-2 text-sm text-ds-text-secondary">
            <li class="flex items-start gap-2">
              <span class="text-ds-partition mt-0.5 shrink-0">&bull;</span>
              <span>Deploy services to Linux or container targets</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-ds-partition mt-0.5 shrink-0">&bull;</span>
              <span>Have 3+ environments or multi-tenant infrastructure</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-ds-partition mt-0.5 shrink-0">&bull;</span>
              <span>Are tired of maintaining deployment scripts and runbooks</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="text-center scroll-reveal scroll-reveal-delay-4">
        <ContactForm
          formType="pioneer"
          buttonText="Apply to the Pioneer Program"
          id="pioneer-form"
        />
        <p class="text-xs text-ds-text-muted mt-3">No commitment. No credit card. Just a conversation.</p>
      </div>
    </div>
  </section>

  <!-- License Details -->
  <section class="py-28 border-t border-ds-border">
    <div class="mx-auto max-w-3xl px-6">
      <div class="text-center mb-12 scroll-reveal">
        <p class="section-heading">License</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Business Source License 1.1</h2>
      </div>

      <div class="glass-card p-8 scroll-reveal scroll-reveal-delay-1">
        <div class="space-y-4 text-sm text-ds-text-secondary leading-relaxed">
          <p>
            Synth is licensed under the
            <strong class="text-ds-text">Business Source License 1.1</strong>.
            You can use, modify, and distribute the source code freely for non-production
            use. Production use is permitted for deployments with up to
            <strong class="text-ds-text">10 registered Envoy agents</strong>.
          </p>
          <p>
            Production use beyond 10 Envoys, or offering Synth as a managed service,
            requires a commercial license. Contact
            <span class="text-ds-accent">licensing@synthdeploy.com</span>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 border-t border-ds-border relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-ds-accent/5 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 text-center scroll-reveal">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Questions?</h2>
      <p class="text-ds-text-secondary text-lg mb-8 max-w-xl mx-auto">
        Whether you're evaluating Synth for your team or interested in the Pioneer Program,
        we'd like to hear from you.
      </p>
      <div class="flex flex-col items-center gap-4">
        <div class="flex items-center gap-4">
          <ContactForm
            formType="general"
            buttonText="Get in Touch"
            id="general-form"
          />
          <a
            href="/docs/installation"
            class="rounded-md border border-ds-border px-6 py-3 text-ds-text hover:border-ds-accent-border hover:bg-ds-surface transition-colors"
          >
            Installation Guide
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
  );

  document.querySelectorAll(".scroll-reveal").forEach((el) => observer.observe(el));
</script>
