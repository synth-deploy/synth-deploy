<!-- Hero demo orchestrator -->
<script>
(function () {
  const demo = document.getElementById("hero-demo");
  if (!demo) return;

  let paused = false;
  let currentTimeout = null;
  const pendingTimeouts = [];

  // Pause on hover
  demo.addEventListener("mouseenter", () => { paused = true; });
  demo.addEventListener("mouseleave", () => { paused = false; });

  function wait(ms) {
    return new Promise((resolve) => {
      function tick() {
        if (paused) {
          const id = setTimeout(tick, 50);
          pendingTimeouts.push(id);
          return;
        }
        if (ms <= 0) { resolve(); return; }
        const chunk = Math.min(ms, 50);
        ms -= chunk;
        const id = setTimeout(tick, chunk);
        pendingTimeouts.push(id);
      }
      tick();
    });
  }

  function showStage(id) {
    demo.querySelectorAll(".demo-stage").forEach((s) => s.classList.add("hidden"));
    const stage = document.getElementById(id);
    if (stage) {
      stage.classList.remove("hidden");
      stage.classList.remove("fade-out");
    }
  }

  async function fadeToStage(id) {
    const current = demo.querySelector(".demo-stage:not(.hidden)");
    if (current) {
      current.classList.add("fade-out");
      await wait(400);
    }
    showStage(id);
  }

  // ── Stage 1: Intake ──────────────────────────────
  async function runIntake() {
    showStage("stage-intake");
    const card = document.getElementById("artifact-card");
    const zone = document.getElementById("drop-zone");
    // Reset
    card.className = "artifact-dragging absolute rounded-lg border border-ds-accent-border bg-ds-surface px-4 py-3";
    card.style.right = "-200px";
    card.style.top = "80px";
    zone.classList.remove("accepting");

    await wait(600);
    // Card slides in from right
    card.style.opacity = "1";
    card.classList.add("entering");
    await wait(1000);
    // Land in drop zone
    zone.classList.add("accepting");
    card.classList.remove("entering");
    card.classList.add("landed");
    await wait(800);
  }

  // ── Stage 2: Analysis ─────────────────────────────
  async function runAnalysis() {
    await fadeToStage("stage-analysis");
    const lines = document.querySelectorAll("#analysis-lines .analysis-line");
    const bar = document.querySelector(".analysis-progress");

    // Reset
    lines.forEach((l) => { l.classList.remove("visible"); l.style.opacity = "0"; });
    bar.style.width = "0%";
    bar.style.transition = "none";

    await wait(200);
    // Start progress
    bar.style.transition = "width 2.5s cubic-bezier(0.22, 1, 0.36, 1)";
    bar.style.width = "100%";

    // Reveal lines sequentially
    for (let i = 0; i < lines.length; i++) {
      await wait(550);
      lines[i].classList.add("visible");
    }
    await wait(600);
  }

  // ── Stage 3: Select target ────────────────────────
  async function runSelect() {
    await fadeToStage("stage-select");
    const row1 = document.getElementById("envoy-row-1");
    row1.classList.remove("selected");

    await wait(800);
    // Highlight first envoy
    row1.classList.add("selected");
    await wait(1000);
  }

  // ── Stage 4: Plan generation ──────────────────────
  async function runPlan() {
    await fadeToStage("stage-plan");
    const assessment = document.getElementById("plan-assessment");
    const steps = document.querySelectorAll(".plan-step");
    const actions = document.getElementById("plan-actions");
    const btn = document.getElementById("greenlight-btn");

    // Reset
    assessment.classList.remove("visible");
    steps.forEach((s) => s.classList.remove("visible"));
    actions.classList.remove("visible");
    btn.classList.remove("pulse", "clicked");

    await wait(400);
    assessment.classList.add("visible");
    await wait(300);
    for (const step of steps) {
      await wait(250);
      step.classList.add("visible");
    }
    await wait(300);
    actions.classList.add("visible");
    await wait(500);
    // Pulse then click greenlight
    btn.classList.add("pulse");
    await wait(1200);
    btn.classList.add("clicked");
    await wait(600);
  }

  // ── Stage 5: Execution ────────────────────────────
  async function runExec() {
    await fadeToStage("stage-exec");
    const steps = document.querySelectorAll(".exec-step");

    // Reset all steps
    steps.forEach((s) => {
      s.querySelector(".exec-icon").className = "exec-icon flex-shrink-0 w-5 h-5 rounded-full bg-ds-border text-ds-text-muted text-[10px] font-semibold flex items-center justify-center";
      s.querySelector(".exec-status").className = "exec-status text-[10px] text-ds-text-muted font-mono";
      s.querySelector(".exec-status").textContent = "waiting";
    });

    await wait(400);

    for (let i = 0; i < steps.length; i++) {
      const icon = steps[i].querySelector(".exec-icon");
      const status = steps[i].querySelector(".exec-status");

      // Mark active
      icon.classList.add("active");
      status.classList.add("active");
      status.textContent = "running";

      // Simulate work
      await wait(700 + Math.random() * 400);

      // Mark done
      icon.classList.remove("active");
      icon.classList.add("done");
      status.classList.remove("active");
      status.classList.add("done");
      status.textContent = "done";
    }

    // Hide spinner
    const spinner = demo.querySelector(".exec-spinner");
    if (spinner) spinner.style.opacity = "0";

    await wait(500);
  }

  // ── Stage 6: Debrief ───────────────────────────────
  async function runDebrief() {
    await fadeToStage("stage-debrief");
    const entries = document.querySelectorAll(".debrief-entry");

    // Reset
    entries.forEach((e) => e.classList.remove("visible"));

    await wait(300);
    // Reveal entries one by one
    for (const entry of entries) {
      await wait(350);
      entry.classList.add("visible");
    }
    // Hold on debrief so viewers can read it
    await wait(4000);
  }

  // ── Main loop ─────────────────────────────────────
  async function runDemo() {
    while (true) {
      await runIntake();
      await runAnalysis();
      await runSelect();
      await runPlan();
      await runExec();
      await runDebrief();
      // Brief pause before loop restart
      await wait(1000);
    }
  }

  // Start when visible (with fallback for immediate visibility)
  let started = false;
  function startOnce() {
    if (started) return;
    started = true;
    runDemo();
  }

  const demoObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        demoObserver.disconnect();
        startOnce();
      }
    },
    { threshold: 0.1 },
  );
  demoObserver.observe(demo);

  // Fallback: if hero is already in view on load, start after a short delay
  setTimeout(() => {
    const rect = demo.getBoundingClientRect();
    if (rect.top < window.innerHeight) {
      demoObserver.disconnect();
      startOnce();
    }
  }, 800);
})();
</script>
