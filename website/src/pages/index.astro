<!-- Scroll reveal + scroll-spy observer -->
<script>
  // Scroll-reveal
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
  );
  document.querySelectorAll(".scroll-reveal").forEach((el) => revealObserver.observe(el));

  // Scroll-spy sidebar
  const nav = document.getElementById("home-nav");
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>(".guide-nav-link");
    const sectionIds = Array.from(links).map((l) => l.dataset.spy!);
    const sections = sectionIds.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    const visited = new Set<string>();

    let navShown = false;
    let firstReveal = true;

    function showNav() {
      if (navShown) return;
      navShown = true;
      nav.style.pointerEvents = "auto";
      if (firstReveal) {
        firstReveal = false;
        links.forEach((link, i) => {
          setTimeout(() => link.classList.add("visible"), i * 60);
        });
      } else {
        links.forEach((link) => link.classList.add("visible"));
      }
    }

    function hideNav() {
      if (!navShown) return;
      navShown = false;
      nav.style.pointerEvents = "none";
      links.forEach((link) => link.classList.remove("visible"));
    }

    // Watch the hero — hide nav when hero is visible, show when it's not
    const hero = document.querySelector("section:first-of-type");
    if (hero) {
      const heroObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              hideNav();
            } else {
              showNav();
            }
          });
        },
        { threshold: 0.15 },
      );
      heroObserver.observe(hero);
    }

    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const id = link.dataset.spy!;
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", `#${id}`);
        }
      });
    });

    const spyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          if (entry.isIntersecting) {
            visited.add(id);
            links.forEach((link) => {
              const spy = link.dataset.spy!;
              link.classList.toggle("active", spy === id);
              link.classList.toggle("visited", visited.has(spy) && spy !== id);
            });
          }
        });
      },
      { threshold: 0, rootMargin: "-30% 0px -50% 0px" },
    );

    sections.forEach((section) => spyObserver.observe(section));
  }
</script>

