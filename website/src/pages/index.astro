<!-- Hero demo orchestrator -->
<script>
(function () {
  const demo = document.getElementById("hero-demo");
  if (!demo) return;

  let paused = false;
  const pendingTimeouts = [];

  demo.addEventListener("mouseenter", () => { paused = true; });
  demo.addEventListener("mouseleave", () => { paused = false; });

  function wait(ms) {
    return new Promise((resolve) => {
      function tick() {
        if (paused) {
          const id = setTimeout(tick, 50);
          pendingTimeouts.push(id);
          return;
        }
        if (ms <= 0) { resolve(); return; }
        const chunk = Math.min(ms, 50);
        ms -= chunk;
        const id = setTimeout(tick, chunk);
        pendingTimeouts.push(id);
      }
      tick();
    });
  }

  function showStage(id) {
    demo.querySelectorAll(".demo-stage").forEach((s) => {
      s.classList.add("hidden");
      s.style.display = "none";
    });
    const stage = document.getElementById(id);
    if (stage) {
      stage.classList.remove("hidden");
      stage.classList.remove("fade-out");
      stage.style.display = "";
    }
  }

  async function fadeToStage(id) {
    const current = demo.querySelector(".demo-stage:not(.hidden)");
    if (current) {
      current.classList.add("fade-out");
      await wait(400);
    }
    showStage(id);
  }

  // ── Stage 0: Artifact Intake ──────────────────────
  async function runIntake() {
    showStage("stage-intake");
    const card = document.getElementById("artifact-card");
    const zone = document.getElementById("drop-zone");
    const label = document.getElementById("intake-label");
    const analysisSection = document.getElementById("intake-analysis");
    const lines = document.querySelectorAll("#analysis-lines .analysis-line");
    const bar = document.getElementById("analysis-bar");

    // Reset
    card.className = "artifact-dragging absolute rounded-lg border border-ds-accent-border bg-ds-surface px-4 py-3";
    card.style.right = "-200px";
    card.style.top = "80px";
    zone.classList.remove("accepting");
    zone.style.display = "flex";
    card.style.display = "";
    analysisSection.style.display = "none";
    lines.forEach((l) => { l.classList.remove("visible"); l.style.opacity = "0"; });
    if (bar) { bar.style.transition = "none"; bar.style.width = "0%"; }
    if (label) label.textContent = "Artifact Intake";

    await wait(600);
    // Card slides in from right
    card.style.opacity = "1";
    card.classList.add("entering");
    await wait(1000);
    // Land in drop zone
    zone.classList.add("accepting");
    card.classList.remove("entering");
    card.classList.add("landed");
    await wait(600);

    // Transition to analysis
    zone.style.display = "none";
    card.style.display = "none";
    if (label) label.textContent = "Analyzing Artifact";
    analysisSection.style.display = "block";

    // Start progress bar
    if (bar) {
      bar.style.transition = "width 2.5s cubic-bezier(0.22, 1, 0.36, 1)";
      bar.style.width = "100%";
    }

    // Reveal lines sequentially
    for (const line of lines) {
      await wait(550);
      line.classList.add("visible");
    }
    await wait(600);
  }

  // ── Stage 1: Operation Authoring ──────────────────
  async function runAuthoring() {
    showStage("stage-authoring");
    const card = document.getElementById("demo-artifact-card");
    const check = document.getElementById("demo-artifact-check");
    const segEnvoy = document.getElementById("seg-envoy");
    const segEnv = document.getElementById("seg-env");
    const segPart = document.getElementById("seg-part");
    const target1 = document.getElementById("demo-target-1");
    const hint = document.getElementById("demo-hint");
    const actionBar = document.getElementById("demo-action-bar");
    const requestBtn = document.getElementById("demo-request-btn");

    // Reset
    card.classList.remove("selected");
    check.classList.remove("checked");
    check.textContent = "";
    segEnvoy.classList.remove("active");
    segEnv.classList.remove("active");
    segPart.classList.remove("active");
    target1.classList.remove("selected");
    if (hint) hint.style.opacity = "0";
    if (actionBar) actionBar.style.opacity = "0";
    requestBtn.classList.remove("clicked");

    await wait(600);

    // 1. Select artifact (checkbox fills)
    card.classList.add("selected");
    check.classList.add("checked");
    check.textContent = "✓";
    await wait(600);

    // 2. Activate "Envoy" tab
    segEnvoy.classList.add("active");
    await wait(500);

    // 3. Select target row (green highlight)
    target1.classList.add("selected");
    await wait(400);

    // 4. Show context hint
    if (hint) hint.style.opacity = "1";
    await wait(400);

    // 5. Show action bar
    if (actionBar) actionBar.style.opacity = "1";
    await wait(600);

    // 6. Click "Request Plan"
    requestBtn.classList.add("clicked");
    await wait(500);
  }

  // ── Stage 2: Reasoning ─────────────────────────────
  const REASONING_STEPS = [
    "Scanning local environment state",
    "Loading previous deployment history",
    "Analyzing artifact dependencies",
    "Reasoning about deployment strategy",
    "Building rollback plan",
    "Finalizing plan",
  ];

  async function runReasoning() {
    await fadeToStage("stage-reasoning");
    const stepText = document.getElementById("reasoning-step-text");
    const dots = document.querySelectorAll("#reasoning-dots .reasoning-dot");
    const elapsedEl = document.getElementById("reasoning-elapsed");

    // Reset
    dots.forEach((d) => { d.style.background = "rgba(255,255,255,0.07)"; });
    if (stepText) stepText.textContent = REASONING_STEPS[0] + "…";
    if (elapsedEl) elapsedEl.textContent = "0s elapsed";

    // Elapsed timer
    let secs = 0;
    const timer = setInterval(() => {
      if (!paused) {
        secs++;
        if (elapsedEl) elapsedEl.textContent = secs + "s elapsed";
      }
    }, 1000);

    await wait(300);

    // Advance through steps
    for (let i = 0; i < REASONING_STEPS.length; i++) {
      if (stepText) stepText.textContent = REASONING_STEPS[i] + "…";
      dots[i].style.background = "#6b8aff";
      await wait(600);
    }

    clearInterval(timer);
    await wait(400);
  }

  // ── Stage 3: Plan Review ──────────────────────────
  async function runPlan() {
    await fadeToStage("stage-plan");
    const assessment = document.getElementById("plan-assessment");
    const stepsLabel = document.getElementById("plan-steps-label");
    const steps = document.querySelectorAll("#plan-steps-container .plan-step");
    const actions = document.getElementById("plan-actions");
    const btn = document.getElementById("greenlight-btn");

    // Reset
    assessment.classList.remove("visible");
    assessment.style.opacity = "0";
    if (stepsLabel) { stepsLabel.classList.remove("visible"); stepsLabel.style.opacity = "0"; }
    steps.forEach((s) => { s.classList.remove("visible"); s.style.opacity = "0"; });
    actions.classList.remove("visible");
    actions.style.opacity = "0";
    btn.classList.remove("pulse", "clicked");

    await wait(400);

    // Assessment fades in
    assessment.classList.add("visible");
    assessment.style.opacity = "1";
    await wait(400);

    // Steps label
    if (stepsLabel) { stepsLabel.classList.add("visible"); stepsLabel.style.opacity = "1"; }
    await wait(200);

    // Steps reveal one-by-one
    for (const step of steps) {
      await wait(200);
      step.classList.add("visible");
      step.style.opacity = "1";
    }
    await wait(300);

    // Action buttons
    actions.classList.add("visible");
    actions.style.opacity = "1";
    await wait(500);

    // Pulse then click greenlight
    btn.classList.add("pulse");
    await wait(1200);
    btn.classList.add("clicked");
    await wait(600);
  }

  // ── Stage 4: Execution ────────────────────────────
  async function runExec() {
    await fadeToStage("stage-exec");
    const steps = demo.querySelectorAll("#stage-exec .exec-step");
    const elapsed = document.getElementById("exec-elapsed");
    const healthEl = document.getElementById("exec-health");
    const progressFill = document.getElementById("exec-progress-fill");
    const stepDurations = ["2.1s", "8.4s", "34.2s", "0.8s", "12.6s"];

    // Reset all steps
    steps.forEach((s) => {
      const badge = s.querySelector(".exec-badge");
      if (badge) {
        badge.className = "exec-badge";
        badge.style.cssText = "width:20px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;font-family:'IBM Plex Mono',monospace;flex-shrink:0;background:#2e313b;color:#6a6660;";
      }
      const status = s.querySelector(".exec-status");
      if (status) { status.className = "exec-status text-[10px] text-ds-text-muted font-mono"; status.textContent = "waiting"; }
      const dur = s.querySelector(".exec-duration");
      if (dur) { dur.textContent = ""; dur.className = "exec-duration text-[10px] text-ds-text-muted font-mono"; }
    });
    if (elapsed) elapsed.textContent = "0.0s";
    if (healthEl) healthEl.style.opacity = "0";
    if (progressFill) progressFill.style.width = "0%";
    const spinner = demo.querySelector(".exec-spinner");
    if (spinner) spinner.style.opacity = "1";

    // Elapsed timer
    let elapsedMs = 0;
    const timerInterval = setInterval(() => {
      if (!paused) {
        elapsedMs += 100;
        if (elapsed) elapsed.textContent = (elapsedMs / 1000).toFixed(1) + "s";
      }
    }, 100);

    await wait(400);

    for (let i = 0; i < steps.length; i++) {
      const badge = steps[i].querySelector(".exec-badge");
      const status = steps[i].querySelector(".exec-status");
      const dur = steps[i].querySelector(".exec-duration");

      // Mark active
      if (badge) badge.classList.add("active");
      if (status) { status.classList.add("active"); status.textContent = "running"; }

      // Update progress bar
      if (progressFill) progressFill.style.width = ((i + 0.5) / steps.length * 100) + "%";

      // Simulate work
      await wait(500 + Math.random() * 400);

      // Mark done
      if (badge) { badge.classList.remove("active"); badge.classList.add("done"); }
      if (status) { status.classList.remove("active"); status.classList.add("done"); status.textContent = "done"; }
      if (dur) { dur.textContent = stepDurations[i]; dur.classList.add("done"); }

      // Update progress bar
      if (progressFill) progressFill.style.width = ((i + 1) / steps.length * 100) + "%";
    }

    clearInterval(timerInterval);
    if (elapsed) elapsed.textContent = "57.4s";
    if (healthEl) healthEl.style.opacity = "1";
    if (spinner) spinner.style.opacity = "0";

    await wait(800);
  }

  // ── Stage 5: Debrief ───────────────────────────────
  async function runDebrief() {
    await fadeToStage("stage-debrief");
    const assessment = document.getElementById("debrief-assessment");
    const logLabel = document.getElementById("debrief-log-label");
    const cards = demo.querySelectorAll("#stage-debrief .demo-debrief-tl .debrief-entry");

    // Reset
    const allEntries = demo.querySelectorAll("#stage-debrief .debrief-entry");
    allEntries.forEach((e) => { e.classList.remove("visible"); e.style.opacity = "0"; });

    await wait(300);

    // Assessment fades in
    if (assessment) assessment.classList.add("visible");
    await wait(700);

    // Decision Log label
    if (logLabel) logLabel.classList.add("visible");
    await wait(300);

    // Cards reveal one by one
    for (const card of cards) {
      await wait(400);
      card.classList.add("visible");
    }
    await wait(4000);
  }

  // ── Main loop ─────────────────────────────────────
  async function runDemo() {
    while (true) {
      await runIntake();
      await runAuthoring();
      await runReasoning();
      await runPlan();
      await runExec();
      await runDebrief();
      await wait(1000);
    }
  }

  let started = false;
  function startOnce() {
    if (started) return;
    started = true;
    runDemo();
  }

  const demoObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        demoObserver.disconnect();
        startOnce();
      }
    },
    { threshold: 0.1 },
  );
  demoObserver.observe(demo);

  setTimeout(() => {
    const rect = demo.getBoundingClientRect();
    if (rect.top < window.innerHeight) {
      demoObserver.disconnect();
      startOnce();
    }
  }, 800);
})();
</script>
