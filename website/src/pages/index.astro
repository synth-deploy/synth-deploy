---
import Layout from "../layouts/Layout.astro";
import SynthMark from "../components/SynthMark.astro";
---

<Layout title="Synth — Operations that reason." description="Synth is an intelligent operations system. Describe the objective — Synth plans against your actual infrastructure, you approve, and execution is exact. Self-hosted, MCP-native, open source.">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-ds-accent/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-ds-partition/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 pt-24 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: tagline + CTAs -->
        <div class="animate-fade-in-up text-center lg:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-[3.25rem] font-display font-bold leading-tight mb-6">
            Operations that <span class="text-ds-accent">reason</span>.
          </h1>
          <p class="text-lg text-ds-text-secondary max-w-lg mx-auto lg:mx-0 mb-2 leading-relaxed font-semibold">
            Intelligent planning. Human approval. Deterministic execution.
          </p>
          <p class="text-base text-ds-text-muted max-w-lg mx-auto lg:mx-0 mb-8 leading-relaxed">
            Describe any operational objective — deploy, investigate, maintain, query.
            Synth plans against your actual infrastructure, explains every decision,
            and executes exactly what you approved.
          </p>
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-8">
            <a
              href="https://github.com/synth-deploy/synth"
              target="_blank"
              rel="noopener"
              class="rounded-md bg-ds-accent px-6 py-3 text-ds-bg font-semibold hover:bg-ds-accent/90 transition-colors"
            >
              Get Started
            </a>
            <a
              href="/docs"
              class="rounded-md border border-ds-border px-6 py-3 text-ds-text hover:border-ds-accent-border hover:bg-ds-surface transition-colors"
            >
              Read the Docs
            </a>
            <a href="/roadmap" class="rounded-md border border-ds-border px-6 py-3 text-ds-text-secondary hover:border-ds-accent-border hover:bg-ds-surface transition-colors">
              Roadmap
            </a>
          </div>
          <p class="text-sm text-ds-text-muted">Source-available&ensp;·&ensp;Self-hosted&ensp;·&ensp;MCP-native</p>
        </div>

        <!-- Right: animated demo -->
        <div class="animate-fade-in-up animate-delay-2">
          <div id="hero-demo" class="glass-card accent-glow overflow-hidden text-left relative" style="min-height: 460px;">
            <!-- Fake window chrome -->
            <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-ds-border bg-ds-bg/40">
              <span class="w-2.5 h-2.5 rounded-full bg-ds-failed/40"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ds-warning/40"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ds-succeeded/40"></span>
              <span class="ml-3 text-[10px] font-mono text-ds-text-muted">Synth</span>
            </div>

            <!-- Stage 0: Artifact Intake — drag-in + analysis -->
            <div id="stage-intake" class="demo-stage px-5 pt-5 pb-5">
              <p id="intake-label" class="text-[10px] font-semibold uppercase tracking-widest text-ds-text-muted mb-4">Artifact Intake</p>
              <div id="drop-zone" class="rounded-lg border-2 border-dashed border-ds-border flex items-center justify-center" style="height: 120px;">
                <p class="text-sm text-ds-text-muted">Drop an artifact to begin</p>
              </div>
              <div id="artifact-card" class="artifact-dragging absolute rounded-lg border border-ds-accent-border bg-ds-surface px-4 py-3" style="right: -200px; top: 80px;">
                <div class="flex items-center gap-2.5">
                  <div class="w-8 h-8 rounded-md bg-ds-accent/15 flex items-center justify-center">
                    <span class="text-ds-accent text-xs font-bold">C</span>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-ds-text">payments-api</p>
                    <p class="text-[11px] text-ds-text-muted font-mono">v3.2.1 · container</p>
                  </div>
                </div>
              </div>
              <!-- Analysis section — shown after drop -->
              <div id="intake-analysis" style="display:none;">
                <div class="rounded-lg border border-ds-accent-border bg-ds-accent/5 px-4 py-3 mb-3">
                  <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 rounded-md bg-ds-accent/15 flex items-center justify-center">
                      <span class="text-ds-accent text-xs font-bold">C</span>
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-ds-text">payments-api</p>
                      <p class="text-[11px] text-ds-text-muted font-mono">v3.2.1 · container</p>
                    </div>
                  </div>
                </div>
                <div id="analysis-lines" class="space-y-2 font-mono text-xs">
                  <p class="analysis-line text-ds-text-muted opacity-0"><span class="text-ds-dt-scan">■</span> Detected: Docker container image</p>
                  <p class="analysis-line text-ds-text-muted opacity-0"><span class="text-ds-dt-config">■</span> Base: node:20-alpine · 3 layers</p>
                  <p class="analysis-line text-ds-text-muted opacity-0"><span class="text-ds-dt-plan">■</span> Ports: 3000/tcp · Health: /health</p>
                  <p class="analysis-line text-ds-text-muted opacity-0"><span class="text-ds-succeeded">■</span> Checksum verified · No CVEs found</p>
                </div>
                <div class="mt-4 h-1 rounded-full bg-ds-border overflow-hidden">
                  <div id="analysis-bar" class="analysis-progress h-full rounded-full bg-ds-accent" style="width: 0%"></div>
                </div>
              </div>
            </div>

            <!-- Stage 1: Operation Authoring -->
            <div id="stage-authoring" class="demo-stage px-4 pt-4 pb-4 hidden">
              <!-- Page title -->
              <div style="margin-bottom: 10px;">
                <p class="font-display text-[15px] font-medium text-ds-text" style="margin: 0 0 2px;">New Operation</p>
                <p class="text-[10px] text-ds-text-muted" style="margin: 0;">Select what and where. Synth figures out how.</p>
              </div>

              <!-- Operation type selector -->
              <div class="demo-op-selector">
                <span id="demo-op-deploy" class="demo-op-pill active">Deploy</span>
                <span class="demo-op-pill">Maintain</span>
                <span class="demo-op-pill">Query</span>
                <span class="demo-op-pill">Investigate</span>
                <span class="demo-op-pill">Trigger</span>
                <span class="demo-op-pill">Composite</span>
              </div>

              <!-- Two-column layout -->
              <div style="display: grid; grid-template-columns: 3fr 2fr; gap: 14px;">
                <!-- What column -->
                <div>
                  <p class="demo-section-label">What</p>
                  <div id="demo-artifact-card" class="demo-nd-artifact-card">
                    <span id="demo-artifact-check" class="demo-nd-check"></span>
                    <div style="flex: 1; min-width: 0;">
                      <div style="display: flex; align-items: baseline; gap: 6px;">
                        <span style="font-size: 12px; font-weight: 600; color: #e4e2de;">payments-api</span>
                        <span style="font-size: 10px; color: #6a6660; font-family: 'IBM Plex Mono', monospace;">container</span>
                      </div>
                      <div style="font-size: 9px; color: #6a6660; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Node.js container image, health at /health</div>
                      <!-- Confidence indicator -->
                      <div id="demo-ci" style="display: inline-flex; align-items: center; gap: 4px; margin-top: 3px;">
                        <span style="display: inline-block; width: 36px; height: 3px; border-radius: 2px; background: rgba(255,255,255,0.07); overflow: hidden;">
                          <span style="display: block; height: 100%; width: 92%; border-radius: 2px; background: #4cbe7a;"></span>
                        </span>
                        <span style="font-size: 9px; font-family: 'IBM Plex Mono', monospace; font-weight: 600; color: #4cbe7a;">High</span>
                        <span style="font-size: 9px; font-family: 'IBM Plex Mono', monospace; color: #6a6660;">understanding</span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Where column -->
                <div>
                  <p class="demo-section-label">Where</p>
                  <!-- Segmented control -->
                  <div class="demo-seg-control" style="margin-bottom: 6px;">
                    <button id="seg-env" class="demo-seg-btn">Env</button>
                    <button id="seg-envoy" class="demo-seg-btn">Envoy</button>
                    <button id="seg-part" class="demo-seg-btn">Part</button>
                  </div>
                  <!-- Target list -->
                  <div class="demo-target-list">
                    <div id="demo-target-1" class="demo-target-row">
                      <span class="demo-status-pip" style="background: #4cbe7a;"></span>
                      <div style="flex: 1; min-width: 0;">
                        <span style="font-size: 11px; font-weight: 500; color: #e4e2de; font-family: 'IBM Plex Mono', monospace;">prd-web-01</span>
                        <div style="font-size: 9px; color: #6a6660; margin-top: 1px;">3s ago</div>
                      </div>
                    </div>
                    <div class="demo-target-row" style="opacity: 0.4;">
                      <span class="demo-status-pip" style="background: #4cbe7a;"></span>
                      <div style="flex: 1; min-width: 0;">
                        <span style="font-size: 11px; font-weight: 500; color: #e4e2de; font-family: 'IBM Plex Mono', monospace;">prd-web-02</span>
                        <div style="font-size: 9px; color: #6a6660; margin-top: 1px;">45s ago</div>
                      </div>
                    </div>
                  </div>
                  <!-- Context hint -->
                  <div id="demo-hint" class="demo-context-hint" style="opacity: 0; transition: opacity 0.3s;">
                    Deploying directly to <span style="color: #22d3ee; font-weight: 500;">prd-web-01</span>. The envoy will produce a plan specific to this host.
                  </div>
                </div>
              </div>

              <!-- Action bar -->
              <div id="demo-action-bar" class="demo-action-bar" style="opacity: 0; transition: opacity 0.3s;">
                <button id="demo-request-btn" class="demo-request-plan-btn">Request Plan</button>
              </div>
            </div>

            <!-- Stage 2: Reasoning -->
            <div id="stage-reasoning" class="demo-stage px-5 pt-5 pb-5 hidden" style="display: none;">
              <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 320px; text-align: center;">
                <!-- SynthMark -->
                <div style="margin-bottom: 16px;">
                  <SynthMark size={44} />
                </div>
                <p style="color: #9a9790; font-size: 14px; font-weight: 600; margin: 0 0 6px;">
                  Reasoning about <span style="color: #e4e2de;">payments-api</span>
                </p>
                <p id="reasoning-step-text" style="color: #6a6660; font-size: 11px; font-family: 'IBM Plex Mono', monospace; margin: 0 0 16px; min-height: 16px;">
                  Scanning local environment state…
                </p>
                <!-- Progress dots -->
                <div id="reasoning-dots" style="display: flex; justify-content: center; gap: 6px; margin-bottom: 16px;">
                  <span class="reasoning-dot" style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.07); transition: background 0.4s;"></span>
                  <span class="reasoning-dot" style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.07); transition: background 0.4s;"></span>
                  <span class="reasoning-dot" style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.07); transition: background 0.4s;"></span>
                  <span class="reasoning-dot" style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.07); transition: background 0.4s;"></span>
                  <span class="reasoning-dot" style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.07); transition: background 0.4s;"></span>
                  <span class="reasoning-dot" style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.07); transition: background 0.4s;"></span>
                </div>
                <p id="reasoning-elapsed" style="color: #6a6660; font-size: 10px; font-family: 'IBM Plex Mono', monospace; margin: 0;">
                  0s elapsed
                </p>
              </div>
            </div>

            <!-- Stage 3: Plan Review -->
            <div id="stage-plan" class="demo-stage px-4 pt-4 pb-3 hidden">
              <!-- Header -->
              <div style="margin-bottom: 8px;">
                <p style="font-size: 10px; color: #6a6660; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; margin: 0 0 3px;">Deployment Plan</p>
                <p class="font-display" style="font-size: 15px; font-weight: 500; color: #e4e2de; margin: 0;">
                  payments-api <span style="color: #6a6660; font-weight: 400; font-size: 11px; font-family: 'IBM Plex Mono', monospace;">v3.2.1</span>
                </p>
                <p style="font-size: 10px; color: #9a9790; margin: 1px 0 0;">&rarr; prd-web-01</p>
              </div>

              <!-- Synth Assessment -->
              <div id="plan-assessment" class="demo-assessment opacity-0">
                <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 5px;">
                  <!-- Mini SynthMark -->
                  <span style="flex-shrink: 0; display: inline-flex;">
                    <SynthMark size={14} />
                  </span>
                  <span style="font-size: 10px; font-weight: 700; color: #6b8aff; text-transform: uppercase; letter-spacing: 1px; font-family: 'IBM Plex Mono', monospace;">Synth Assessment</span>
                  <span style="display: inline-flex; align-items: center; gap: 3px; margin-left: auto;">
                    <span style="display: inline-block; width: 28px; height: 3px; border-radius: 2px; background: rgba(255,255,255,0.07); overflow: hidden;">
                      <span style="display: block; height: 100%; width: 90%; border-radius: 2px; background: #4cbe7a;"></span>
                    </span>
                    <span style="font-size: 9px; font-family: 'IBM Plex Mono', monospace; font-weight: 600; color: #4cbe7a;">High</span>
                    <span style="font-size: 9px; font-family: 'IBM Plex Mono', monospace; color: #6a6660;">confidence</span>
                  </span>
                </div>
                <p style="font-size: 10px; color: #e4e2de; line-height: 1.5; margin: 0;">Identical artifact deployed 11× with 100% success rate. No variable conflicts. Host stable.</p>
              </div>

              <!-- Steps -->
              <div id="plan-steps-container" style="margin-top: 8px;">
                <div class="plan-step demo-plan-step-row opacity-0">
                  <span class="demo-plan-step-num">1</span>
                  <div style="flex: 1; min-width: 0;">
                    <p style="font-size: 10px; color: #e4e2de; margin: 0; line-height: 1.3;">Stop service <span style="font-family: 'IBM Plex Mono', monospace; color: #6a6660;">payments-api</span> via systemd</p>
                    <p style="font-size: 9px; color: #6a6660; margin: 1px 0 0;">&#8617; systemctl start payments-api</p>
                  </div>
                  <span class="demo-risk-label" style="color: #4cbe7a;">low</span>
                </div>
                <div class="plan-step demo-plan-step-row opacity-0">
                  <span class="demo-plan-step-num">2</span>
                  <div style="flex: 1; min-width: 0;">
                    <p style="font-size: 10px; color: #e4e2de; margin: 0; line-height: 1.3;">Backup <span style="font-family: 'IBM Plex Mono', monospace; color: #6a6660;">/opt/payments-api/</span> to rollback store</p>
                    <p style="font-size: 9px; color: #6a6660; margin: 1px 0 0;">&#8617; restore from backup</p>
                  </div>
                  <span class="demo-risk-label" style="color: #4cbe7a;">low</span>
                </div>
                <div class="plan-step demo-plan-step-row opacity-0">
                  <span class="demo-plan-step-num">3</span>
                  <div style="flex: 1; min-width: 0;">
                    <p style="font-size: 10px; color: #e4e2de; margin: 0; line-height: 1.3;">Extract container image to target path</p>
                    <p style="font-size: 9px; color: #6a6660; margin: 1px 0 0;">&#8617; &mdash;</p>
                  </div>
                  <span class="demo-risk-label" style="color: #e05555;">high</span>
                </div>
                <div class="plan-step demo-plan-step-row opacity-0">
                  <span class="demo-plan-step-num">4</span>
                  <div style="flex: 1; min-width: 0;">
                    <p style="font-size: 10px; color: #e4e2de; margin: 0; line-height: 1.3;">Apply env config <span style="font-family: 'IBM Plex Mono', monospace; color: #6a6660;">(LOG_LEVEL: debug→info)</span></p>
                    <p style="font-size: 9px; color: #6a6660; margin: 1px 0 0;">&#8617; revert env file</p>
                  </div>
                  <span class="demo-risk-label" style="color: #4cbe7a;">low</span>
                </div>
                <div class="plan-step demo-plan-step-row opacity-0" style="border-bottom: none;">
                  <span class="demo-plan-step-num">5</span>
                  <div style="flex: 1; min-width: 0;">
                    <p style="font-size: 10px; color: #e4e2de; margin: 0; line-height: 1.3;">Start service, verify health &rarr; 200 OK</p>
                    <p style="font-size: 9px; color: #6a6660; margin: 1px 0 0;">&#8617; systemctl stop payments-api</p>
                  </div>
                  <span class="demo-risk-label" style="color: #6a6660;">none</span>
                </div>
              </div>

              <!-- Action buttons -->
              <div id="plan-actions" class="opacity-0" style="display: flex; gap: 6px; margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.07); transition: opacity 0.35s, transform 0.35s; transform: translateY(6px);">
                <button id="greenlight-btn" class="demo-btn-greenlight" style="flex: 1;">Greenlight</button>
                <button class="demo-btn-refine">Refine</button>
                <button class="demo-btn-reject">Reject</button>
              </div>
            </div>

            <!-- Stage 4: Execution -->
            <div id="stage-exec" class="demo-stage px-5 pt-5 pb-5 hidden">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-ds-text-muted" style="margin: 0;">Executing</p>
                <span class="exec-spinner w-3 h-3 rounded-full border-2 border-ds-accent border-t-transparent"></span>
                <span class="text-[10px] text-ds-text-muted ml-auto font-mono" id="exec-elapsed">0.0s</span>
              </div>
              <!-- Progress bar -->
              <div id="exec-progress-bar" style="width: 100%; height: 2px; border-radius: 1px; background: #2e313b; margin-bottom: 12px; overflow: hidden;">
                <div id="exec-progress-fill" style="height: 100%; border-radius: 1px; background: #6b8aff; width: 0%; transition: width 0.4s ease;"></div>
              </div>
              <div class="space-y-0">
                <div class="exec-step flex items-center gap-2.5 py-1.5 border-b border-ds-border/50">
                  <span class="exec-badge" style="width: 20px; height: 20px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; flex-shrink: 0; background: #2e313b; color: #6a6660;">1</span>
                  <p class="text-[11px] text-ds-text-secondary flex-1" style="margin: 0;">Stop service via systemd</p>
                  <span class="exec-duration text-[10px] text-ds-text-muted font-mono"></span>
                  <span class="exec-status text-[10px] text-ds-text-muted font-mono">waiting</span>
                </div>
                <div class="exec-step flex items-center gap-2.5 py-1.5 border-b border-ds-border/50">
                  <span class="exec-badge" style="width: 20px; height: 20px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; flex-shrink: 0; background: #2e313b; color: #6a6660;">2</span>
                  <p class="text-[11px] text-ds-text-secondary flex-1" style="margin: 0;">Backup to rollback store</p>
                  <span class="exec-duration text-[10px] text-ds-text-muted font-mono"></span>
                  <span class="exec-status text-[10px] text-ds-text-muted font-mono">waiting</span>
                </div>
                <div class="exec-step flex items-center gap-2.5 py-1.5 border-b border-ds-border/50">
                  <span class="exec-badge" style="width: 20px; height: 20px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; flex-shrink: 0; background: #2e313b; color: #6a6660;">3</span>
                  <p class="text-[11px] text-ds-text-secondary flex-1" style="margin: 0;">Extract container image</p>
                  <span class="exec-duration text-[10px] text-ds-text-muted font-mono"></span>
                  <span class="exec-status text-[10px] text-ds-text-muted font-mono">waiting</span>
                </div>
                <div class="exec-step flex items-center gap-2.5 py-1.5 border-b border-ds-border/50">
                  <span class="exec-badge" style="width: 20px; height: 20px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; flex-shrink: 0; background: #2e313b; color: #6a6660;">4</span>
                  <p class="text-[11px] text-ds-text-secondary flex-1" style="margin: 0;">Apply env config</p>
                  <span class="exec-duration text-[10px] text-ds-text-muted font-mono"></span>
                  <span class="exec-status text-[10px] text-ds-text-muted font-mono">waiting</span>
                </div>
                <div class="exec-step flex items-center gap-2.5 py-1.5">
                  <span class="exec-badge" style="width: 20px; height: 20px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; flex-shrink: 0; background: #2e313b; color: #6a6660;">5</span>
                  <p class="text-[11px] text-ds-text-secondary flex-1" style="margin: 0;">Start &amp; verify health</p>
                  <span class="exec-duration text-[10px] text-ds-text-muted font-mono"></span>
                  <span class="exec-status text-[10px] text-ds-text-muted font-mono">waiting</span>
                </div>
              </div>
              <!-- Health check result -->
              <div id="exec-health" class="mt-2.5 rounded-md border border-ds-succeeded/20 bg-ds-succeeded/5 px-3 py-2 opacity-0 transition-opacity duration-300">
                <p class="text-[10px] font-mono text-ds-succeeded" style="margin: 0;">✓ Health endpoint responded 200 in 340ms — rollback plan verified</p>
              </div>
            </div>

            <!-- Stage 5: Debrief -->
            <div id="stage-debrief" class="demo-stage px-4 pt-3 pb-3 hidden">
              <!-- Header -->
              <div style="display:flex;align-items:center;gap:5px;margin-bottom:9px;flex-wrap:nowrap;">
                <span style="font-size:12px;font-weight:600;color:#e4e2de;white-space:nowrap;">payments-api</span>
                <span style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:#6a6660;">v3.2.1</span>
                <span style="font-size:10px;color:#6a6660;margin:0 1px;">→</span>
                <span style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:#6a6660;white-space:nowrap;">prd-web-01</span>
                <span style="margin-left:auto;display:inline-flex;align-items:center;gap:6px;flex-shrink:0;">
