---
import Layout from "../layouts/Layout.astro";
---

<Layout title="DeployStack — Deployment Intelligence, Embedded">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-ds-accent/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-indigo-500/5 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 pt-24 pb-20 text-center">
      <div class="animate-fade-in-up">
        <p class="section-heading">Deployment Platform</p>
        <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
          Stop writing runbooks.<br />
          <span class="text-ds-accent">Start deploying intelligently.</span>
        </h1>
        <p class="text-xl text-ds-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
          DeployStack replaces rigid automation with an intelligent agent that understands
          what you're doing, makes decisions, and explains every one of them. No chatbot.
          No new paradigm. Just a deployment tool that thinks.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a
            href="https://github.com/jmfullerton96/DeployStack"
            target="_blank"
            rel="noopener"
            class="rounded-lg bg-ds-accent px-6 py-3 text-ds-bg font-semibold hover:bg-ds-accent/90 transition-colors"
          >
            Get Started
          </a>
          <a
            href="/docs"
            class="rounded-lg border border-ds-border px-6 py-3 text-ds-text hover:border-ds-accent/30 hover:bg-ds-surface transition-colors"
          >
            Read the Docs
          </a>
        </div>
      </div>

      <!-- Terminal preview -->
      <div class="mt-16 animate-fade-in-up animate-delay-2">
        <div class="glass-card accent-glow max-w-3xl mx-auto overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-ds-border">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            <span class="ml-2 text-xs text-ds-text-muted font-mono">deploystack</span>
          </div>
          <div class="p-6 font-mono text-sm leading-relaxed text-left">
            <p class="text-ds-text-muted">$ deploystack deploy web-app v2.4.1 --partition acme-corp</p>
            <p class="mt-3 text-ds-accent">Agent: Planned 3-step pipeline for web-app v2.4.1</p>
            <p class="text-ds-text-secondary">  1. Install dependencies <span class="text-ds-accent">&#10003;</span> 14.2s</p>
            <p class="text-ds-text-secondary">  2. Run migrations <span class="text-ds-accent">&#10003;</span> 3.1s</p>
            <p class="text-ds-text-secondary">  3. Health check <span class="text-ds-accent">&#10003;</span> 0.2s</p>
            <p class="mt-3 text-ds-accent">Decision: Resolved 4 variables (1 conflict: APP_ENV — environment wins)</p>
            <p class="text-green-400 mt-1">Deployment succeeded in 17.5s</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16">
        <p class="section-heading">Capabilities</p>
        <h2 class="text-3xl md:text-4xl font-bold">Intelligence where friction used to be</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="glass-card p-8 animate-fade-in-up">
          <div class="w-10 h-10 rounded-lg bg-ds-accent-dim flex items-center justify-center mb-4">
            <span class="text-ds-accent text-lg">&#9881;</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">Agent Mode</h3>
          <p class="text-ds-text-secondary leading-relaxed">
            Describe what you want to deploy in natural language. The agent resolves
            operations, partitions, environments, and variables — then executes with
            full decision transparency.
          </p>
        </div>

        <div class="glass-card p-8 animate-fade-in-up animate-delay-1">
          <div class="w-10 h-10 rounded-lg bg-ds-accent-dim flex items-center justify-center mb-4">
            <span class="text-ds-accent text-lg">&#128221;</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">Debrief</h3>
          <p class="text-ds-text-secondary leading-relaxed">
            Every agent decision is logged in plain language. No silent actions. When
            something goes wrong at 2am, the decision log tells you exactly what
            happened, why, and what to do next.
          </p>
        </div>

        <div class="glass-card p-8 animate-fade-in-up animate-delay-2">
          <div class="w-10 h-10 rounded-lg bg-ds-accent-dim flex items-center justify-center mb-4">
            <span class="text-ds-accent text-lg">&#128274;</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">Partition Isolation</h3>
          <p class="text-ds-text-secondary leading-relaxed">
            Absolute data isolation between partitions. No cross-partition access or
            failure propagation. Each partition is a self-contained deployment context
            with its own variables, history, and configuration.
          </p>
        </div>

        <div class="glass-card p-8 animate-fade-in-up animate-delay-3">
          <div class="w-10 h-10 rounded-lg bg-ds-accent-dim flex items-center justify-center mb-4">
            <span class="text-ds-accent text-lg">&#128268;</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">MCP-Native</h3>
          <p class="text-ds-text-secondary leading-relaxed">
            Built on Model Context Protocol from the foundation. Connect external
            data sources, monitoring tools, and CI/CD systems through standardized
            MCP servers — not custom integrations.
          </p>
        </div>

        <div class="glass-card p-8 animate-fade-in-up animate-delay-2">
          <div class="w-10 h-10 rounded-lg bg-ds-accent-dim flex items-center justify-center mb-4">
            <span class="text-ds-accent text-lg">&#128203;</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">Step Type Library</h3>
          <p class="text-ds-text-secondary leading-relaxed">
            27 predefined step types across 7 categories. Create custom steps,
            share them across your organization, and import community templates.
            Every step renders a validated form — no more memorizing CLI flags.
          </p>
        </div>

        <div class="glass-card p-8 animate-fade-in-up animate-delay-3">
          <div class="w-10 h-10 rounded-lg bg-ds-accent-dim flex items-center justify-center mb-4">
            <span class="text-ds-accent text-lg">&#128736;</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">Orders &amp; Snapshots</h3>
          <p class="text-ds-text-secondary leading-relaxed">
            Immutable deployment snapshots capture the exact configuration at
            deployment time. Re-deploy any previous order with confidence. Full
            audit trail from intent to outcome.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-24 border-t border-ds-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16">
        <p class="section-heading">Architecture</p>
        <h2 class="text-3xl md:text-4xl font-bold">How DeployStack works</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center animate-fade-in-up">
          <div class="glass-card w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-mono font-bold text-ds-accent">
            1
          </div>
          <h3 class="text-lg font-semibold mb-2">Command</h3>
          <p class="text-ds-text-secondary text-sm leading-relaxed">
            The central server. Manages operations, partitions, environments,
            and the intelligent agent. Exposes REST API and MCP server.
          </p>
        </div>

        <div class="text-center animate-fade-in-up animate-delay-1">
          <div class="glass-card w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-mono font-bold text-ds-accent">
            2
          </div>
          <h3 class="text-lg font-semibold mb-2">Envoy</h3>
          <p class="text-ds-text-secondary text-sm leading-relaxed">
            Lightweight agents deployed on target machines. Execute deployment
            steps, run health checks, and report results back to Command.
          </p>
        </div>

        <div class="text-center animate-fade-in-up animate-delay-2">
          <div class="glass-card w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-mono font-bold text-ds-accent">
            3
          </div>
          <h3 class="text-lg font-semibold mb-2">Debrief</h3>
          <p class="text-ds-text-secondary text-sm leading-relaxed">
            The decision log. Every action, conflict resolution, and failure
            diagnosis is recorded in plain language. Generates postmortems
            automatically.
          </p>
        </div>
      </div>

      <!-- Flow diagram -->
      <div class="mt-16 glass-card p-8 max-w-3xl mx-auto animate-fade-in-up animate-delay-3">
        <div class="font-mono text-sm text-center space-y-4">
          <div class="flex items-center justify-center gap-4 flex-wrap">
            <span class="rounded-lg border border-ds-accent/30 bg-ds-accent-dim px-3 py-1.5 text-ds-accent">Engineer</span>
            <span class="text-ds-text-muted">&rarr;</span>
            <span class="rounded-lg border border-indigo-400/30 bg-indigo-400/10 px-3 py-1.5 text-indigo-300">Intent / Config</span>
            <span class="text-ds-text-muted">&rarr;</span>
            <span class="rounded-lg border border-ds-accent/30 bg-ds-accent-dim px-3 py-1.5 text-ds-accent">Command</span>
          </div>
          <div class="text-ds-text-muted text-xs">resolves variables, plans pipeline, creates order</div>
          <div class="flex items-center justify-center gap-4 flex-wrap">
            <span class="rounded-lg border border-ds-accent/30 bg-ds-accent-dim px-3 py-1.5 text-ds-accent">Command</span>
            <span class="text-ds-text-muted">&rarr;</span>
            <span class="rounded-lg border border-emerald-400/30 bg-emerald-400/10 px-3 py-1.5 text-emerald-300">Envoy</span>
            <span class="text-ds-text-muted">&rarr;</span>
            <span class="rounded-lg border border-amber-400/30 bg-amber-400/10 px-3 py-1.5 text-amber-300">Target Machine</span>
          </div>
          <div class="text-ds-text-muted text-xs">executes steps, verifies, reports back</div>
          <div class="flex items-center justify-center gap-4 flex-wrap">
            <span class="rounded-lg border border-fuchsia-400/30 bg-fuchsia-400/10 px-3 py-1.5 text-fuchsia-300">Debrief</span>
            <span class="text-ds-text-muted">&larr;</span>
            <span class="text-ds-text-secondary">every decision logged</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 border-t border-ds-border">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to deploy smarter?</h2>
      <p class="text-ds-text-secondary text-lg mb-8 max-w-xl mx-auto">
        DeployStack is open source and self-hosted. Get started in minutes.
      </p>
      <a
        href="https://github.com/jmfullerton96/DeployStack"
        target="_blank"
        rel="noopener"
        class="inline-block rounded-lg bg-ds-accent px-8 py-3 text-ds-bg font-semibold hover:bg-ds-accent/90 transition-colors"
      >
        View on GitHub
      </a>
    </div>
  </section>
</Layout>
