---
import "../styles/global.css";
import SynthMark from "../components/SynthMark.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Deployment intelligence, not deployment automation.",
  image = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL.href} />
    <meta property="og:site_name" content="Synth" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL.href} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Synth",
      "url": "https://synthdeploy.com",
      "logo": "https://synthdeploy.com/favicon.svg",
      "description": "Intelligent deployment system — deployment intelligence, not deployment automation.",
      "sameAs": [
        "https://github.com/synth-deploy/synth"
      ]
    })} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-ds-border bg-ds-header-bg backdrop-blur-lg">
      <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-ds-text">
          <SynthMark size={72} />
          <span>Synth</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/#features" class="text-ds-text-secondary hover:text-ds-text transition-colors">Features</a>
          <a href="/#how-it-works" class="text-ds-text-secondary hover:text-ds-text transition-colors">How It Works</a>
          <a href="/docs" class="text-ds-text-secondary hover:text-ds-text transition-colors">Docs</a>
          <a href="/roadmap" class="text-ds-text-secondary hover:text-ds-text transition-colors">Roadmap</a>
          <a href="/pricing" class="text-ds-text-secondary hover:text-ds-text transition-colors">Pricing</a>
          <a href="/blog" class="text-ds-text-secondary hover:text-ds-text transition-colors">Blog</a>
          <a
            href="https://github.com/synth-deploy/synth"
            target="_blank"
            rel="noopener"
            class="rounded-md border border-ds-accent-border bg-ds-accent-dim px-4 py-1.5 text-ds-accent hover:bg-ds-accent-hover transition-colors font-medium"
          >
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-ds-border mt-24">
      <div class="mx-auto max-w-6xl px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2.5 text-sm text-ds-text-muted">
          <SynthMark size={48} />
          <span>Synth</span>
          <span class="mx-2">&middot;</span>
          <span>Deployment intelligence, embedded.</span>
        </div>
        <div class="flex items-center gap-6 text-sm text-ds-text-muted">
          <a href="/docs" class="hover:text-ds-text transition-colors">Docs</a>
          <a href="/roadmap" class="hover:text-ds-text transition-colors">Roadmap</a>
          <a href="/pricing" class="hover:text-ds-text transition-colors">Pricing</a>
          <a href="/blog" class="hover:text-ds-text transition-colors">Blog</a>
          <a href="https://github.com/synth-deploy/synth" target="_blank" rel="noopener" class="hover:text-ds-text transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
