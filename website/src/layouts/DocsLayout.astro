---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const sections = [
  { title: "Getting Started", href: "/docs" },
  { title: "Installation & Configuration", href: "/docs/installation" },
  { title: "Architecture", href: "/docs/architecture" },
  { title: "API Reference", href: "/docs/api" },
];

const currentPath = Astro.url.pathname;
const isDocsRoot = currentPath === "/docs" || currentPath === "/docs/";
---

<Layout title={`${title} — Synth Docs`} description={description}>
  <div class="mx-auto max-w-6xl px-6 py-12 flex gap-8">
    <aside class="hidden md:block w-56 shrink-0">
      <nav class="sticky top-24 space-y-1">
        <p class="section-heading mb-4">Documentation</p>
        {sections.map((s) => (
          <a
            href={s.href}
            class:list={[
              "block rounded-lg px-3 py-2 text-sm transition-colors",
              currentPath === s.href || currentPath === s.href + "/"
                ? "bg-ds-accent-dim text-ds-accent font-medium"
                : "text-ds-text-secondary hover:text-ds-text hover:bg-ds-surface",
            ]}
          >
            {s.title}
          </a>
        ))}
      </nav>
    </aside>
    <div class="flex-1 min-w-0">
      <nav aria-label="Breadcrumb" class="text-sm text-ds-text-muted mb-4">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-ds-accent transition-colors">Home</a></li>
          <li><span class="mx-1">/</span></li>
          <li><a href="/docs" class="hover:text-ds-accent transition-colors">Docs</a></li>
          {!isDocsRoot && (
            <>
              <li><span class="mx-1">/</span></li>
              <li class="text-ds-text">{title}</li>
            </>
          )}
        </ol>
      </nav>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://synthdeploy.com/" },
          { "@type": "ListItem", "position": 2, "name": "Docs", "item": "https://synthdeploy.com/docs" },
          ...(!isDocsRoot
            ? [{ "@type": "ListItem", "position": 3, "name": title, "item": `https://synthdeploy.com${currentPath}` }]
            : []),
        ],
      })} />
      <article class="prose-docs">
        <slot />
      </article>
    </div>
  </div>
</Layout>
