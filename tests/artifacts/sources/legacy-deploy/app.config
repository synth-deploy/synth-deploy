# synth-demo-worker configuration
# All values can be overridden by environment variables

APP_ENV=production
LOG_LEVEL=warn
HEALTH_PORT=8080

# Database
DB_HOST=
DB_PORT=5432
DB_NAME=worker
DB_POOL_SIZE=10

# Message queue
QUEUE_URL=amqp://localhost
QUEUE_PREFETCH=4
WORKER_CONCURRENCY=4

# Artifact repository (required for deploy.sh)
ARTIFACT_REPO_URL=
