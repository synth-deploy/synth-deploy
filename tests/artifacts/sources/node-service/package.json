{
  "name": "synth-demo-api",
  "version": "2.1.0",
  "description": "Demo REST API service for Synth integration testing",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "deploy": "npm run build && pm2 reload synth-demo-api --update-env"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "pino": "^8.17.1",
    "pino-http": "^9.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "tsx": "^4.6.2",
    "vitest": "^1.1.0"
  }
}
