{
  "name": "@synth-deploy/server",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "synth-server": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./agent/*": "./dist/agent/*",
    "./api/*": "./dist/api/*",
    "./mcp/*": "./dist/mcp/*"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=../../.env --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@synth-deploy/core": "*",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@node-saml/node-saml": "^5.1.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.0.0",
    "ldapjs": "^3.0.7",
    "openid-client": "^6.8.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^25.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
