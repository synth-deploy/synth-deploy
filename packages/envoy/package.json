{
  "name": "@deploystack/envoy",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "deploystack-envoy": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./agent/*": "./dist/agent/*",
    "./execution/*": "./dist/execution/*",
    "./state/*": "./dist/state/*",
    "./server.js": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@deploystack/core": "*",
    "fastify": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
