# Synth Environment Configuration
# Copy this file to .env and fill in the values.

# --- Required for production ---

# JWT secret for signing session tokens. If not set, a random secret is generated
# on each restart (sessions will not survive restarts).
# SYNTH_JWT_SECRET=your-jwt-secret-here

# Dedicated encryption key for IdP client secrets at rest (AES-256-GCM).
# REQUIRED before configuring any identity providers. Must be different from
# SYNTH_JWT_SECRET to ensure a single compromised key does not expose
# both session tokens and IdP credentials.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SYNTH_ENCRYPTION_KEY=your-encryption-key-here

# --- LLM Configuration ---

# Anthropic API key (required — Synth is non-functional without an LLM connection)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override Anthropic base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Server ---

# PORT=3000
# HOST=0.0.0.0

# CORS origin(s). Comma-separated for multiple origins.
# SYNTH_CORS_ORIGIN=http://localhost:5173

# --- Data ---

# Directory for SQLite databases and other persistent data
# SYNTH_DATA_DIR=data

# Set to "false" to skip seeding demo data on first run
# SYNTH_SEED_DEMO=true

# --- Rate Limiting ---

# SYNTH_RATE_LIMIT_MAX=100
# SYNTH_RATE_LIMIT_WINDOW_MS=60000
