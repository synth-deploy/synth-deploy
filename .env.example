# Synth Environment Configuration
# Copy this file to .env and fill in the values.

# --- Required for production ---

# JWT secret for signing session tokens.
# Optional — if not set, a secret is auto-generated on first run and stored in
# SYNTH_DATA_DIR/jwt-secret (mode 0600). Sessions survive restarts automatically.
# Set this explicitly for multi-instance deployments or to force key rotation.
# SYNTH_JWT_SECRET=your-jwt-secret-here

# Dedicated encryption key for IdP client secrets at rest (AES-256-GCM).
# REQUIRED before configuring any identity providers. Must be different from
# SYNTH_JWT_SECRET to ensure a single compromised key does not expose
# both session tokens and IdP credentials.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SYNTH_ENCRYPTION_KEY=your-encryption-key-here

# --- LLM Configuration ---

# LLM API key (required — Synth is non-functional without an LLM connection)
# For Anthropic: sk-ant-...  For OpenAI-compatible: your provider's key.
# SYNTH_LLM_API_KEY=sk-ant-...

# LLM provider (default: anthropic). Supported: anthropic, bedrock, vertex, openai-compatible
# SYNTH_LLM_PROVIDER=anthropic

# Optional: override provider base URL (e.g. for Ollama: http://localhost:11434/v1)
# SYNTH_LLM_BASE_URL=https://api.anthropic.com

# --- Server ---

# PORT=3000
# HOST=0.0.0.0

# CORS origin(s). Comma-separated for multiple origins.
# SYNTH_CORS_ORIGIN=http://localhost:5173

# --- Data ---

# Directory for SQLite databases and other persistent data
# SYNTH_DATA_DIR=data

# Set to "false" to skip seeding demo data on first run
# SYNTH_SEED_DEMO=true

# --- Rate Limiting ---

# SYNTH_RATE_LIMIT_MAX=100
# SYNTH_RATE_LIMIT_WINDOW_MS=60000
