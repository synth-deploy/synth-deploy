{
  "name": "synth-deploy",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/server -w packages/envoy -w packages/ui",
    "dev": "npm run dev --workspace=packages/server",
    "dev:ui": "npm run dev --workspace=packages/ui",
    "build:ui": "npm run build --workspace=packages/ui",
    "test": "npm test --workspace=packages/core --workspace=packages/server --workspace=packages/envoy --workspace=packages/ui",
    "test:coverage": "npm test --workspace=packages/core --workspace=packages/server --workspace=packages/envoy --workspace=packages/ui -- --coverage",
    "test:integration": "vitest run --config tests/vitest.config.ts",
    "test:scenarios": "vitest run --config tests/vitest.config.ts scenarios/",
    "test:playbooks": "vitest run --config tests/vitest.config.ts scenarios/playbook.test.ts",
    "exercise": "tsx tests/playbooks/cli.ts",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "yaml": "^2.8.3"
  }
}
