{
  "name": "deploystack",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/server",
    "dev:ui": "npm run dev --workspace=packages/ui",
    "build:ui": "npm run build --workspace=packages/ui",
    "test": "npm test --workspace=packages/core --workspace=packages/server --workspace=packages/tentacle",
    "clean": "rm -rf packages/*/dist"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
